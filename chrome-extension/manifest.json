{
  "manifest_version": 3,
  "name": "HttpsTypeSearch Autofill",
  "version": "0.1.0",
  "description": "Query local HttpsTypeSearch API by URL and autofill login forms.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://127.0.0.1/*",
    "https://localhost/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "HttpsTypeSearch",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ]
}
